# OpenOptions Lab API Environment Variables

# Application
DEBUG=false
APP_NAME="OpenOptions Lab API"
APP_VERSION="1.0.0"

# Server
HOST=0.0.0.0
PORT=8000

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=openoptions
POSTGRES_PASSWORD=openoptions123
POSTGRES_DB=openoptions

# Database - TimescaleDB
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_USER=openoptions
TIMESCALE_PASSWORD=openoptions123
TIMESCALE_DB=openoptions

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Data Sources (Optional)
# TUSHARE_TOKEN=your-tushare-token
AKSHARE_ENABLE=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Cache TTL (seconds)
CACHE_TTL_MARKET_SNAPSHOT=5
CACHE_TTL_SYMBOL_DETAIL=10
CACHE_TTL_USER_DATA=300
